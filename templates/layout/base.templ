package layout

templ Base(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title }</title>
			<link href="/static/tailwind.css" rel="stylesheet">
			<script src="/static/htmx.min.js"></script>
		</head>
		<body class="min-h-screen">
			{ children... }
		</body>
	</html>
}
